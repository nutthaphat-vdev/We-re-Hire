# WeHire — Environment Variables
# Copy to .env และแก้ค่าให้ตรง

# Supabase connection string
# ดูได้ที่: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT Secret — สุ่มให้ยาวๆ อย่างน้อย 32 chars
# gen ได้ด้วย: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-this-in-production

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS — แยกด้วย comma (ไม่มีช่องว่าง)
# Dev: เพิ่ม http://127.0.0.1:5500 (VSCode Live Server)
# Prod: เปลี่ยนเป็น domain จริง
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,null
